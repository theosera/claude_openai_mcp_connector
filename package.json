{
  "name": "claude-openai-mcp-connector",
  "version": "0.1.0",
  "description": "Local MCP server for safely sharing a private Markdown knowledge vault with Claude, ChatGPT-compatible clients, and Codex.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "claude-openai-mcp-connector": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:ox": "oxlint src tests",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "dev": "tsx src/index.ts"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "diff": "^9.0.0",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^8.0.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
