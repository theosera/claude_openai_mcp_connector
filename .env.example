# Local clone path for your private Obsidian/Markdown vault.
# Do not commit a real path or private repository URL.
KNOWLEDGE_ROOT=/path/to/private/obsidian-vault

# Existing files are edited through a plan/apply flow.
MCP_WRITE_MODE=two_step

# Patch proposals are local state and ignored by git.
MCP_PATCH_STATE_DIR=.mcp-state/patches

# --- Remote HTTP transport (for ChatGPT / Claude.ai Chat connectors) ---
# Select transport: "stdio" (default, local CLI clients) or "http" (remote Chat).
MCP_TRANSPORT=stdio

# Bearer secret every HTTP request must present. REQUIRED when MCP_TRANSPORT=http.
# Generate a long random value; never commit the real token.
MCP_AUTH_TOKEN=replace-with-a-long-random-secret

# HTTP bind host/port. Default binds to loopback only; expose via a tunnel.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787

# Read-only by default. Set to 1/true to also expose write tools over HTTP.
MCP_HTTP_ALLOW_WRITE=

# DNS-rebinding protection. Comma-separated. Defaults to host:port + localhost:port.
# When tunneling, add your public hostname, e.g. vault.example.com.
MCP_HTTP_ALLOWED_HOSTS=
MCP_HTTP_ALLOWED_ORIGINS=

# Optional public base for ChatGPT citation URLs (else vault:// is used).
MCP_HTTP_PUBLIC_URL=

# --- OAuth 2.1 authorization server (for ChatGPT / Claude.ai web) ---
# ChatGPT/Claude.ai web cannot send a static bearer; enable OAuth for them.
MCP_OAUTH_ENABLED=
# Required when OAuth is enabled: the public HTTPS issuer URL (your tunnel URL).
# MCP_HTTP_PUBLIC_URL is reused as the OAuth issuer (set it above).
# Shared login password gating vault access at the OAuth consent screen.
MCP_OAUTH_PASSWORD=replace-with-a-vault-login-password
# Token lifetimes (seconds). Sensible defaults if unset.
MCP_OAUTH_ACCESS_TTL=3600
MCP_OAUTH_REFRESH_TTL=2592000
MCP_OAUTH_CODE_TTL=60
