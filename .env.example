# Copy this file to .env. The repository helpers (`pnpm run start:http`,
# `check:http`, and `funnel:*`) load that exact file; per-shell exports are not
# required. Keep .env local and mode 0600 because it contains secrets.

# Local clone path for your private Obsidian/Markdown vault.
# Do not commit a real path or private repository URL.
KNOWLEDGE_ROOT=/path/to/private/obsidian-vault

# Optional: serve SEVERAL roots at once (e.g. the vault + a command-log repo).
# Comma-separated name=path pairs. The FIRST root is the primary (writable);
# every other root is strictly read-only and its documents are addressed as
# "name:relative/path". When set, KNOWLEDGE_ROOTS takes precedence over
# KNOWLEDGE_ROOT. Roots must be disjoint directories.
#KNOWLEDGE_ROOTS=vault=/path/to/private/obsidian-vault,ops=/path/to/ops-log-repo

# --- session-archive hook (Claude Code session history -> vault) ---
# Optional overrides for .claude/skills/session-archive/archive-session.sh.
# By default the hook finds the vault clone by scanning $HOME/*/ for a
# `.claude-session-vault` marker file; unset + no marker = the hook is a no-op.
#SESSION_VAULT_REPO=/path/to/private/obsidian-vault
#SESSION_LOG_SUBDIR=claude-sessions
#SESSION_ARCHIVE_DISABLE=

# Existing files are edited through a plan/apply flow.
MCP_WRITE_MODE=two_step

# Patch proposals are local state and ignored by git.
MCP_PATCH_STATE_DIR=.mcp-state/patches

# Max Markdown files opened at once during a vault scan. Bounds file-descriptor
# pressure on large vaults (a naive all-at-once open can surface as transient
# EAGAIN/EMFILE, esp. on iCloud/network-backed folders). Default 24 if unset.
#MCP_SCAN_CONCURRENCY=24

# Optional constrained destination for instruction-only Skill bundles. This is
# relative to the primary knowledge root and must already exist. Existing Skills
# are never overwritten.
#MCP_SKILLS_SUBDIR=path/to/skills

# --- Remote HTTP transport (for ChatGPT / Claude.ai Chat connectors) ---
# Select transport: "stdio" (default, local CLI clients) or "http" (remote Chat).
MCP_TRANSPORT=stdio

# Bearer secret every HTTP request must present. REQUIRED when MCP_TRANSPORT=http.
# Generate a long random value; never commit the real token.
MCP_AUTH_TOKEN=replace-with-a-long-random-secret

# HTTP bind host/port. Default binds to loopback only; expose via a tunnel.
# `pnpm run funnel:start` exposes this port through Tailscale Funnel.
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8787

# Read-only by default. Set to 1/true to also expose write tools over HTTP.
MCP_HTTP_ALLOW_WRITE=

# Independently expose only the constrained Skill plan/apply tools over HTTP.
# Requires MCP_SKILLS_SUBDIR and does not expose general document write tools.
MCP_HTTP_ALLOW_SKILL_WRITE=

# DNS-rebinding protection. Comma-separated. Defaults to host:port + localhost:port.
# When tunneling, add your public hostname, e.g. vault.example.com.
MCP_HTTP_ALLOWED_HOSTS=
MCP_HTTP_ALLOWED_ORIGINS=

# Public base for ChatGPT citations and the OAuth issuer. For Tailscale Funnel,
# use https://<machine>.<tailnet>.ts.net (without /mcp).
MCP_HTTP_PUBLIC_URL=

# --- OAuth 2.1 authorization server (for ChatGPT / Claude.ai web) ---
# ChatGPT/Claude.ai web cannot send a static bearer; enable OAuth for them.
MCP_OAUTH_ENABLED=
# Required when OAuth is enabled: the public HTTPS issuer URL (your tunnel URL).
# MCP_HTTP_PUBLIC_URL is reused as the OAuth issuer (set it above).
# Shared login password gating vault access at the OAuth consent screen.
MCP_OAUTH_PASSWORD=replace-with-a-vault-login-password
# Token lifetimes (seconds). Sensible defaults if unset.
MCP_OAUTH_ACCESS_TTL=3600
MCP_OAUTH_REFRESH_TTL=2592000
MCP_OAUTH_CODE_TTL=60
# Optional: persist OAuth sessions across server restarts (off = in-memory,
# every restart forces a re-authorize). Points at a state FILE the server
# creates (0600). Tokens are stored as sha256 hashes (nothing recoverable) and
# the file is integrity-protected with a key derived from MCP_OAUTH_PASSWORD —
# rotating the password revokes all persisted sessions.
# MCP_OAUTH_STATE_FILE=/abs/path/to/state/oauth-state.json
