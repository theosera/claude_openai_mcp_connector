.DS_Store
.env
.env.*
*oauth-state*.json
!.env.example

node_modules/
.pnpm-store/
dist/
coverage/
.vitest/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.mcp-state/

# Guard rails: do not commit private vault material into the public code repo.
vault/
knowledge/
data/

# Secrets / credentials — never commit (defense in depth with .claude/settings.json
# read-deny rules). .env / .env.* are already excluded above (.env.example allowed).
*.key
*.pem
credentials*.json
service-account*.json
*token*.json
secrets/
secrets.json
secrets.yaml
secrets.yml

# Local Claude Code overrides (personal vault path / endpoints) — never shared.
.claude/settings.local.json

# OAuth session state (MCP_OAUTH_STATE_FILE) — local-only auth state, never commit
*oauth-state*.json
